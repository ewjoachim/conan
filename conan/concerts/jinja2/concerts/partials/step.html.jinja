<div class="step {% if is_step_done(step, state) %}completed{% endif %} {% if step.parallel %}parallel{% endif %}" id="step_{{ step.id }}">
  <div class="step-header" onclick="this.parentElement.classList.toggle('open')">
    <span class="step-title">{{ step.title }}</span>
    <span class="step-chevron">▼</span>
  </div>
  <div class="step-body">
    {% for item in step.items %}{% include "concerts/partials/item.html.jinja" %}{% endfor %}
  </div>
</div>
