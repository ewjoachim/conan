<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}CONAN{% endblock %}</title>
  <link rel="stylesheet" href="{{ static('conan/app.css') }}">
  <script src="{{ static('conan/htmx.min.js') }}" defer></script>
</head>
<body hx-headers='{"X-CSRFToken": "{{ csrf_token }}"}'>
  {% block body %}{% endblock %}

  <footer class="version-footer">CONAN v{{ conan_version }}</footer>

  <script>
    // Drive the header save indicator from HTMX request lifecycle events.
    function setSave(state) {
      var el = document.getElementById('save-indicator');
      if (!el) return;
      el.className = 'save-indicator ' + state;
      el.textContent = state === 'saving' ? 'Sauvegarde…' : state === 'saved' ? '✓ Sauvegardé' : '—';
    }
    document.body.addEventListener('htmx:beforeRequest', function () { setSave('saving'); });
    document.body.addEventListener('htmx:afterRequest', function (e) {
      setSave(e.detail.successful ? 'saved' : '');
    });
  </script>
  {% block scripts %}{% endblock %}
</body>
</html>
